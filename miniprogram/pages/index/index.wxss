/* pages/index/index.wxss - 首页样式 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 32rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(102,126,234,0.3);
}
.header-title { font-size: 40rpx; font-weight: 700; margin-bottom: 8rpx; }
.header-date { font-size: 28rpx; opacity: 0.9; }
.header-update { font-size: 22rpx; opacity: 0.7; margin-top: 8rpx; }

.refresh-bar { margin-bottom: 24rpx; display: flex; justify-content: flex-end; }
.refresh-btn {
  background: #667eea; color: #fff; border-radius: 30rpx;
  padding: 12rpx 32rpx; font-size: 26rpx;
}

.dashboard {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.dash-card {
  background: #fff; border-radius: 12rpx; padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  border-left: 6rpx solid #ddd;
}
.dash-card.has-news { border-left-color: #52c41a; }
.dash-card.no-news { border-left-color: #bfbfbf; opacity: 0.8; }
.dash-card-title { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.dash-card-count { font-size: 48rpx; font-weight: 700; }
.dash-card.has-news .dash-card-count { color: #52c41a; }
.dash-card.no-news .dash-card-count { color: #999; }
.dash-card-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 20rpx; display: inline-block; margin-top: 8rpx; }
.has-news .dash-card-status { background: #f6ffed; color: #389e0d; }
.no-news .dash-card-status { background: #f5f5f5; color: #999; }

.section { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); }
.section-header { display: flex; align-items: center; margin-bottom: 20rpx; padding-bottom: 12rpx; border-bottom: 2rpx solid #f0f0f0; }
.section-title { font-size: 30rpx; font-weight: 600; }
.section-arrow { margin-left: auto; font-size: 24rpx; color: #667eea; }

.news-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.news-item:last-child { border-bottom: none; }
.news-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 8rpx; }
.news-meta { font-size: 22rpx; color: #999; margin-bottom: 8rpx; }
.news-summary { font-size: 26rpx; color: #555; line-height: 1.7; }
.news-tags { margin-top: 8rpx; }

.job-item { padding: 16rpx; border: 1rpx solid #f0f0f0; border-radius: 8rpx; margin-bottom: 12rpx; background: #fafafa; }
.job-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.job-salary { font-size: 26rpx; color: #f5222d; font-weight: 600; margin-top: 8rpx; }
.job-company { font-size: 26rpx; color: #666; margin-top: 8rpx; }
.job-tags { margin-top: 8rpx; margin-bottom: 8rpx; }
.job-desc { font-size: 24rpx; color: #555; line-height: 1.6; }

.notice-box { background: #fff7e6; border: 1rpx solid #ffd591; border-radius: 8rpx; padding: 20rpx; margin-bottom: 12rpx; }
.notice-title { font-weight: 600; color: #d46b08; margin-bottom: 8rpx; font-size: 28rpx; }
.notice-content { font-size: 26rpx; color: #555; line-height: 1.7; }

.error-box { text-align: center; padding: 60rpx 0; color: #999; }
.error-retry { color: #667eea; margin-top: 16rpx; font-size: 28rpx; }

.footer { text-align: center; padding: 32rpx 0; color: #999; font-size: 24rpx; }
